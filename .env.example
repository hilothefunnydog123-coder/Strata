# Copy to .env and fill in. In production set these as host env vars (Render, etc.).

# Database. SQLite by default (put the file on a persistent disk in production).
# To use Postgres: set provider="postgresql" in prisma/schema.prisma and use a
# postgres:// URL here.
DATABASE_URL="file:./dev.db"

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# The platform owner (superadmin) account, created by the seed on first run.
OWNER_EMAIL="owner@yourcompany.com"
OWNER_PASSWORD="a-strong-password"
OWNER_NAME="Platform Owner"
